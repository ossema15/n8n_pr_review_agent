    {
      "parameters": {
        "jsCode": "const files = $input.all().map(item => item.json);\n\n// 1. Count total lines changed\nconst totalChanges = files.reduce((sum, f) => {\n  return sum + (f.additions || 0) + (f.deletions || 0);\n}, 0);\n\n// 2. Calculate size label\nfunction getSizeLabel(lines) {\n  if (lines < 10)  return 'XS';\n  if (lines < 50)  return 'S';\n  if (lines < 200) return 'M';\n  if (lines < 500) return 'L';\n  return 'XL';\n}\nconst sizeLabel = getSizeLabel(totalChanges);\n\n// 3. Extract file paths\nconst filePaths = files.map(f => f.filename);\n\n// 4. Build a patch summary (cap at 3000 chars for the AI node)\nconst patchSummary = files\n  .map(f => `### ${f.filename}\\n${f.patch || ''}`)\n  .join('\\n\\n')\n  .slice(0, 3000);\n\n// 5. Return everything downstream nodes need\nreturn [{\n  json: {\n    totalChanges,\n    sizeLabel,\n    filePaths,\n    patchSummary,\n    fileCount: files.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
